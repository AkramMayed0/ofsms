{
  "name": "ofsms",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/backend\" \"npm run dev --workspace=apps/frontend\"",
    "lint": "eslint apps/*/src --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"apps/*/src/**/*.{js,jsx,ts,tsx,json}\""
  },
  "devDependencies": {
    "@babel/eslint-parser": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "puppeteer": "^25.0.2"
  }
}
